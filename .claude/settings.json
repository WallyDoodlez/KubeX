{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm update -g @playwright/cli && playwright-cli install --skills 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Updating Playwright CLI skills..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch",
      "Skill(gsd:new-project)",
      "Skill(gsd:update)",
      "Skill(gsd:plan-phase)",
      "Skill(gsd:discuss-phase)",
      "Skill(gsd:verify-work)",
      "Skill(gsd:add-todo)",
      "Skill(gsd:complete-milestone)",
      "Skill(gsd:audit-milestone)",
      "Skill(gsd:new-milestone)",
      "Skill(gsd:insert-phase)",
      "Skill(gsd:next)",
      "Skill(update-config)"
    ]
  }
}
