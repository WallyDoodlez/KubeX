            E2["12:03:44 тАФ code-agent тЖТ ESCALATE тЖТ create_pr"]
            E3["12:03:42 тАФ email-agent тЖТ activate_kubex тЖТ PENDING APPROVAL"]
        end

        subgraph alerts["Active Alerts"]
            direction TB
            A1["тЪая╕П code-agent CPU at 67% тАФ approaching limit"]
            A2["ЁЯФФ 2 pending human approvals (oldest: 3min)"]
        end
    end

    style overview fill:#1a1a2e,stroke:#e94560,color:#fff
    style fleet fill:#264653,stroke:#fff,color:#fff
    style live-feed fill:#2d6a4f,stroke:#fff,color:#fff
    style alerts fill:#9b2226,stroke:#fff,color:#fff
```

- Click any Kubex tile тЖТ opens the **Agent Detail View**
- Click any feed item тЖТ opens the **action detail** with full context
- Click any alert тЖТ opens the relevant view with pre-filtered context

