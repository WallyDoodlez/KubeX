# KubexClaw Environment Variables
# Copy to .env and fill in values before running docker-compose

# Redis
REDIS_PASSWORD=changeme-redis-password

# Neo4j
NEO4J_PASSWORD=changeme-neo4j-password

# Kubex Manager API token
MANAGER_TOKEN=changeme-manager-token

# Default LLM model for Graphiti
DEFAULT_LLM_MODEL=gpt-4o-mini
